<form>
  <p class="notes">Drag rows to reorder. Check <strong>Hidden</strong> to remove from sheet.</p>

  {{#if hasTabs}}
  <div class="tab-settings-list">
    {{#each tabs}}
    <div class="tab-settings-row" data-label-key="{{labelKey}}" draggable="true">
      <i class="fa-solid fa-grip-vertical tab-drag-handle"></i>
      <span class="tab-settings-label">{{label}}</span>
      <label class="tab-settings-hidden-label">
        <input class="tab-hidden-check" type="checkbox" {{#if hidden}}checked{{/if}}> Hidden
      </label>
      {{#if showRadio}}
      <div class="tab-settings-overrides">
        {{#each overrides}}
        <label class="tab-override-option">
          <input type="radio" name="override-{{../labelKey}}" value="{{index}}" {{#if checked}}checked{{/if}}>
          {{displayLabel}}
        </label>
        {{/each}}
      </div>
      {{/if}}
    </div>
    {{/each}}
  </div>
  {{else}}
  <p class="notification warning">Open a character sheet first so the full tab list can be detected.</p>
  {{/if}}

  <footer class="sheet-footer">
    <button type="button" data-action="reset"><i class="fa-solid fa-rotate-left"></i> Reset</button>
    <button type="button" data-action="save"><i class="fa-solid fa-save"></i> Save</button>
  </footer>
</form>
