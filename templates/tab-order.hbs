<form>
  {{#if hasTabs}}
  <nav class="sheet-navigation tabs tab-settings-nav" data-group="tab-settings">
    {{#each tabs}}
    <a class="item tab-settings-tab{{#if @first}} active{{/if}}" data-label-key="{{labelKey}}" draggable="true">
      {{label}}
    </a>
    {{/each}}
  </nav>

  {{#each tabs}}
  <div class="tab-settings-panel{{#if @first}} active{{/if}}" data-label-key="{{labelKey}}">
    <h2 class="tab-settings-title">{{label}}</h2>
    <label class="tab-settings-hidden-label">
      <input class="tab-hidden-check" type="checkbox" {{#if hidden}}checked{{/if}}> Hidden
    </label>
    {{#if showRadio}}
    <div class="tab-settings-overrides">
      <p class="tab-settings-overrides-label">Override</p>
      {{#each overrides}}
      <label class="tab-override-option">
        <input type="radio" name="override-{{../labelKey}}" value="{{index}}" {{#if checked}}checked{{/if}}>
        {{displayLabel}}
      </label>
      {{/each}}
    </div>
    {{/if}}
  </div>
  {{/each}}

  {{else}}
  <p class="notification warning">No tabs detected yet. Open a character sheet first.</p>
  {{/if}}

  <footer class="sheet-footer">
    <button type="button" data-action="reset"><i class="fa-solid fa-rotate-left"></i> Reset</button>
    <button type="button" data-action="save"><i class="fa-solid fa-save"></i> Save</button>
  </footer>
</form>
